generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  FARMER
  CONSULTANT
  ADMIN
}

enum FieldType {
  GREENHOUSE
  OPEN_FIELD
  ORCHARD
}

enum AnalysisStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum GrowthStage {
  SEEDLING
  VEGETATIVE
  FLOWERING
  FRUITING
  HARVEST
}

enum RecommendationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVISED
}

enum AutomationMode {
  AUTO
  MANUAL
}

enum EventSeverity {
  INFO
  WARNING
  CRITICAL
}

enum WeatherCondition {
  SUNNY
  CLOUDY
  RAINY
  WINDY
  STORMY
}

enum SensorDataSource {
  SIMULATION
  MANUAL
  DEVICE_API
}

enum WeatherDataSource {
  SIMULATION
  MANUAL
  EXTERNAL_API
}

enum NotificationType {
  SENSOR_ALERT
  WEATHER_ALERT
  AUTOMATION_EVENT
  AI_RECOMMENDATION
  SYSTEM
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

enum NotificationSource {
  SIMULATION
  DEVICE_API
  SYSTEM
  USER_ACTION
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(FARMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     Membership[]
  fields          Field[]
  recommendations Recommendation[] @relation("FarmerRecommendations")
  reviews         ConsultantReview[]
  notifications   Notification[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  fields      Field[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(FARMER)
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Field {
  id                String         @id @default(cuid())
  name              String
  type              FieldType      @default(OPEN_FIELD)
  areaHectares      Float?
  locationLat       Float?
  locationLng       Float?
  userId            String
  organizationId    String?
  automationEnabled Boolean        @default(true)
  automationMode    AutomationMode @default(AUTO)
  irrigationOn      Boolean        @default(false)
  ventilationOn     Boolean        @default(false)
  lightingOn        Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization?     @relation(fields: [organizationId], references: [id])
  crops            Crop[]
  soilAnalyses     SoilAnalysis[]
  waterAnalyses    WaterAnalysis[]
  recommendations  Recommendation[]
  sensorReadings   SensorReading[]
  automationEvents AutomationEvent[]
  weatherReadings  WeatherReading[]
}

model AutomationEvent {
  id        String        @id @default(cuid())
  fieldId   String
  type      String
  message   String
  severity  EventSeverity @default(INFO)
  createdAt DateTime      @default(now())

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model SensorReading {
  id            String           @id @default(cuid())
  fieldId       String
  temperature   Float?
  humidity      Float?
  ph            Float?
  ec            Float?
  lightLevel    Float?
  soilMoisture  Float?
  irrigationOn  Boolean          @default(false)
  ventilationOn Boolean          @default(false)
  lightingOn    Boolean          @default(false)
  source        SensorDataSource @default(SIMULATION)
  deviceId      String?
  apiKeyLabel   String?
  createdAt     DateTime         @default(now())

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model Crop {
  id              String      @id @default(cuid())
  name            String
  variety         String?
  fieldId         String
  plantedAt       DateTime?
  growthStage     GrowthStage @default(SEEDLING)
  expectedHarvest DateTime?
  plantCount      Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  field           Field            @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]
  soilAnalyses    SoilAnalysis[]
}

model SoilAnalysis {
  id            String         @id @default(cuid())
  fieldId       String
  cropId        String?
  status        AnalysisStatus @default(DRAFT)
  ph            Float?
  ec            Float?
  nitrogen      Float?
  phosphorus    Float?
  potassium     Float?
  organicMatter Float?
  notes         String?
  analyzedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  field           Field            @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  crop            Crop?            @relation(fields: [cropId], references: [id])
  recommendations Recommendation[]
}

model WaterAnalysis {
  id        String         @id @default(cuid())
  fieldId   String
  status    AnalysisStatus @default(DRAFT)
  ph        Float?
  ec        Float?
  hardness  Float?
  nitrate   Float?
  notes     String?
  analyzedAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  field           Field            @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]
}

model Recommendation {
  id              String               @id @default(cuid())
  title           String
  content         String
  status          RecommendationStatus @default(DRAFT)
  farmerId        String
  fieldId         String?
  cropId          String?
  soilAnalysisId  String?
  waterAnalysisId String?
  consultantNote           String?
  appliedAt                DateTime?
  // Fertigation plan fields
  targetPh                 String?
  targetEc                 String?
  irrigationLitersPerPlant Float?
  irrigationFrequency      String?
  nitrogenAdvice           String?
  phosphorusAdvice         String?
  potassiumAdvice          String?
  fertilizerPlan           String?
  riskSummary              String?
  estimatedCost            String?
  confidenceScore          Float?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  farmer        User           @relation("FarmerRecommendations", fields: [farmerId], references: [id])
  field         Field?         @relation(fields: [fieldId], references: [id])
  crop          Crop?          @relation(fields: [cropId], references: [id])
  soilAnalysis  SoilAnalysis?  @relation(fields: [soilAnalysisId], references: [id])
  waterAnalysis WaterAnalysis? @relation(fields: [waterAnalysisId], references: [id])
  reviews       ConsultantReview[]
}

model WeatherReading {
  id                 String            @id @default(cuid())
  fieldId            String
  outsideTemperature Float?
  outsideHumidity    Float?
  rainChance         Float?
  windSpeed          Float?
  solarRadiation     Float?
  condition          WeatherCondition  @default(SUNNY)
  source             WeatherDataSource @default(SIMULATION)
  provider           String?
  createdAt          DateTime          @default(now())

  field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model Notification {
  id                       String               @id @default(cuid())
  userId                   String
  title                    String
  message                  String
  type                     NotificationType
  severity                 NotificationSeverity @default(INFO)
  isRead                   Boolean              @default(false)
  source                   NotificationSource   @default(SYSTEM)
  relatedFieldId           String?
  relatedAnalysisId        String?
  relatedRecommendationId  String?
  createdAt                DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model ConsultantReview {
  id               String   @id @default(cuid())
  recommendationId String
  consultantId     String
  comment          String?
  approved         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  consultant     User           @relation(fields: [consultantId], references: [id])
}
